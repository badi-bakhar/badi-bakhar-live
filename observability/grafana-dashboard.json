{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "OpenCode tool call metrics from Prometheus Pushgateway",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Total Tool Calls (all time)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(toolcall_total)",
          "legendFormat": "Total calls",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Distinct Tools Used",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count(count by (tool) (toolcall_total))",
          "legendFormat": "Distinct tools",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Total Output Bytes Produced",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(toolcall_output_bytes)",
          "legendFormat": "Output bytes",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Calls per Tool (bar)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-BlYlRd" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sort_desc(sum by (tool) (toolcall_total))",
          "legendFormat": "{{tool}}",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Tool Call Rate (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (tool) (rate(toolcall_total[1m])) * 60",
          "legendFormat": "{{tool}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Tool Call Share (pie)",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (tool) (toolcall_total)",
          "legendFormat": "{{tool}}",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
      "title": "Output Bytes per Tool",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "continuous-GrYlRd" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sort_desc(sum by (tool) (toolcall_output_bytes))",
          "legendFormat": "{{tool}}",
          "instant": true
        }
      ]
    },
    {
      "id": 8,
      "title": "Calls per Session",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "basic"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-BlPu" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sort_desc(sum by (session) (toolcall_session_total))",
          "legendFormat": "{{session}}",
          "instant": true
        }
      ]
    },
    {
      "id": 9,
      "title": "Subagent Spawns per Agent Type",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-RdYlGr" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sort_desc(sum by (agent) (subagent_spawned_total))",
          "legendFormat": "{{agent}}",
          "instant": true
        }
      ]
    },
    {
      "id": 10,
      "title": "Subagent Duration (seconds)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "continuous-BlYlRd" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sort_desc(subagent_duration_seconds)",
          "legendFormat": "{{agent}} ({{session}})",
          "instant": true
        }
      ]
    },
    {
      "id": 11,
      "title": "Subagent Spawn Rate (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (agent) (rate(subagent_spawned_total[1m])) * 60",
          "legendFormat": "{{agent}}"
        }
      ]
    },
    {
      "id": 12,
      "title": "Tool Calls: Primary vs Subagent Sessions",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(toolcall_session_total{parent_session=\"\"})",
          "legendFormat": "Primary session",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(toolcall_session_total{parent_session!=\"\"})",
          "legendFormat": "Subagent sessions",
          "instant": true
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["opencode", "badi-bakhar"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "OpenCode Tool Call Metrics",
  "uid": "opencode-toolcalls-v1",
  "version": 3
}
